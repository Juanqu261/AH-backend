# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xyz.neon.tech/catalog

# Shopify API (Admin API for sync)
SHOPIFY_STORE=tu-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxx
SHOPIFY_STOREFRONT_TOKEN=xxxxx

# Cloudinary (Image CDN)
CLOUDINARY_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx

# Frontend (CORS origin)
FRONTEND_URL=http://localhost:4200

# Cron Job Configuration
SYNC_CRON_SCHEDULE=0 */4 * * *
SYNC_ENABLED=true
SYNC_ADMIN_KEY=your-secret-key

# Server
NODE_ENV=development
PORT=3000