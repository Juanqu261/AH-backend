// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/.prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// MODELOS DE CATÁLOGO
// ============================================

model Product {
  id              Int       @id @default(autoincrement())
  
  // IDs de sincronización con Shopify
  shopifyId       String?   @unique           
  shopifyHandle   String?                     // handle del producto en Shopify
  
  // Datos básicos del producto
  name            String
  description     String?   @db.Text
  priceCents      Int?      // Base price in cents (usually from first variant)
  
  // Relaciones
  variants        ProductVariant[]
  images          ProductImage[]
  
  // Auditoría de sincronización
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shopifyId])
  @@index([lastSyncedAt])
}

model ProductVariant {
  id              Int       @id @default(autoincrement())
  productId       Int
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // IDs de Shopify
  shopifyId       String    @unique          // ID único del variant en Shopify
  
  // Datos esenciales del variant
  sku             String?
  title           String                      // Nombre del variant (ej: "Rojo - M")
  
  // Precios (en cents para evitar problemas de decimales)
  priceCents      Int                         // Precio actual en cents (USD)
  compareAtPriceCents Int?                    // Precio original/comparación en cents
  
  // Disponibilidad e inventario
  availableForSale Boolean   @default(true)
  sellableQuantity Int       @default(0)     // Cantidad vendible online (mejor que inventoryQuantity)
  
  // Imágenes del variant (algunos variants pueden tener sus propias imágenes)
  images          ProductImage[]
  
  // Auditoría
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shopifyId])
  @@index([productId])
}

model ProductImage {
  id              Int       @id @default(autoincrement())
  
  // IDs de Shopify
  shopifyId       String?   @unique
  
  // URLs e información
  url             String
  altText         String?
  
  // Relaciones (una imagen puede estar en Product o ProductVariant)
  productId       Int?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  variantId       Int?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  // URLs cloudinary
  cloudinaryUrl   String?   // URL después de uploading a Cloudinary
  
  // Orden de visualización
  position        Int       @default(0)
  
  // Auditoría
  createdAt       DateTime  @default(now())

  @@index([productId])
  @@index([variantId])
  @@unique([productId, position])
  @@unique([variantId, position])
}
